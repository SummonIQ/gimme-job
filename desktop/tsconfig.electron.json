{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "allowJs": false,
    "lib": ["ES2022", "DOM"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "noEmit": false,
    "outDir": "dist-electron",
    "rootDir": ".",
    "target": "ES2022",
    "types": ["node"]
  },
  "exclude": [
    "electron/**/__tests__/**",
    "electron/admin/bundle-entry.ts"
  ],
  "include": ["electron/**/*.ts", "electron/**/*.cts", "scripts/**/*.ts"]
}
