{
  "expo": {
    "name": "Gimme Job",
    "slug": "gimme-job",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "gimmejob",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#4338ca"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.gimmejob.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.gimmejob.app",
      "adaptiveIcon": {
        "backgroundColor": "#4338ca",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      }
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-web-browser",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#4338ca"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "61cd93a4-54e4-4472-b58a-1f3639f3734c"
      }
    },
    "owner": "summoniq",
    "runtimeVersion": "exposdk:54.0.0",
    "updates": {
      "url": "https://u.expo.dev/61cd93a4-54e4-4472-b58a-1f3639f3734c"
    }
  }
}
