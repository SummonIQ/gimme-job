/// Per-(hostname, actionType) token bucket that persists across desktop /
/// replay process restarts. Shared between the desktop runner and any
/// network-replay recipe so a single host never exceeds its configured
/// rolling or per-day rate.
model HostRateLimitState {
  id               String   @id @default(cuid())
  hostname         String
  actionType       String

  // Rolling bucket (seconds / minutes granularity).
  tokens           Float
  capacity         Float
  refillRatePerSec Float
  lastRefilledAt   DateTime @default(now())

  // Per-day counter, resets at UTC midnight boundaries.
  dayCount         Int      @default(0)
  dayLimit         Int?
  dayResetAt      DateTime

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([hostname, actionType])
  @@index([hostname])
}

/// P4.2 - A recorded HTTP-only submission recipe for a specific ATS
/// family (or host). The ordered request sequence, extracted tokens,
/// and confirmation detector together reproduce a manual submission
/// without driving a browser. Used by `NetworkRecipeRunner` (P4.3).
///
/// A recipe is only `ACTIVE` after the owner manually confirmed the
/// captured waterfall (`source=OWNER_CONFIRMED`). Community and
/// inferred recipes start `SHADOW` and are only promoted after
/// regression-suite parity with the CDP runner.
model NetworkSubmissionRecipe {
  id                    String                 @id @default(cuid())
  family                String
  hostname              String?
  atsSystemId           String?
  version               Int                    @default(1)
  status                NetworkRecipeStatus    @default(SHADOW)
  source                NetworkRecipeSource    @default(COMMUNITY)
  confidence            Float                  @default(0)
  /// Ordered HTTP calls that reconstruct a submission. Each entry:
  ///   { method, url, headers, bodyTemplate?, expectStatus? }
  requestSequence       Json
  /// Named tokens pulled from prior response bodies/headers.
  /// Entry shape: { name, source: "response"|"header", from: stepIndex,
  /// path: jsonpath|cssSelector|headerName, required: boolean }
  variableTokens        Json?
  /// Required. Matches the final response that means "submission
  /// accepted". Shape enforced by `recipe-schema.ts`:
  ///   {
  ///     statusCode?: number,           // exact match on final response
  ///     bodyRegex?: string,            // regex against body text
  ///     headerMatches?: Array<{ header, regex }>
  ///   }
  /// At least one of statusCode / bodyRegex / headerMatches MUST be
  /// present. A recipe without a confirmation detector cannot promote.
  confirmationDetector  Json
  /// Optional per-host rate-limit override. If absent, `HostRateLimitState`
  /// governs dispatch.
  rateLimit             Json?
  notes                 String?
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  atsSystem             ATSSystem?             @relation(fields: [atsSystemId], references: [id], onDelete: SetNull)

  @@unique([family, version])
  @@index([family])
  @@index([hostname])
  @@index([atsSystemId])
  @@index([status, updatedAt])
}

enum NetworkRecipeStatus {
  ACTIVE
  SHADOW
  DISABLED
}

enum NetworkRecipeSource {
  OWNER_CONFIRMED
  COMMUNITY
  INFERRED
}

// Local-only archive of every application form HTML the desktop runtime
// has captured. The HTML itself lives on the user's filesystem under
