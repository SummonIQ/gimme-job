/// Learned phrases that indicate an application was SUCCESSFULLY submitted
/// (e.g. "Thanks for applying", "We received your application"). Captured
/// whenever a training run completes a full submission so auto-submit can
/// reliably detect the positive terminal state. Grows per-hostname and
/// per-ATS over time, separate from closed-posting detection.
model SubmissionConfirmationPhrase {
  id                String   @id @default(cuid())
  hostname          String
  atsSystemId       String?
  normalizedPhrase  String
  originalPhrase    String
  exampleUrl        String?
  observationCount  Int      @default(1)
  firstObservedAt   DateTime @default(now())
  lastObservedAt    DateTime @default(now())
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  atsSystem         ATSSystem? @relation(fields: [atsSystemId], references: [id], onDelete: SetNull)

  @@unique([hostname, normalizedPhrase])
  @@index([hostname])
  @@index([atsSystemId])
  @@index([lastObservedAt])
}

/// Learned phrases that indicate a job posting is expired, filled, or
/// otherwise no longer accepting applications. Captured whenever the
/// closed-posting detector (or an equivalent AI signal) fires on a page,
/// so we can grow a per-hostname corpus and identify unavailable jobs
/// faster over time. This is intentionally separate from the AI-assist
/// rule-learning tables — it is not used to drive automation decisions.
model ClosedPostingPhrase {
  id                String   @id @default(cuid())
  hostname          String
  normalizedPhrase  String
  originalPhrase    String
  detectorReason    String?
  exampleUrl        String?
  observationCount  Int      @default(1)
  firstObservedAt   DateTime @default(now())
  lastObservedAt    DateTime @default(now())
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([hostname, normalizedPhrase])
  @@index([hostname])
  @@index([lastObservedAt])
}

