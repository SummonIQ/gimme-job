/// A long-lived API token issued to a paired desktop install. The raw
/// token never hits the DB - only a SHA-256 hash is stored.
/// Scopes are an array of strings so new capabilities (`desktop:audit`,
/// `desktop:identity-read`) can be added without a schema change.
model DesktopToken {
  id            String    @id @default(cuid())
  userId        String
  label         String // e.g. "Steven MacBook Pro"
  deviceOs      String? // e.g. darwin-24.4.0
  tokenHash     String    @unique // sha-256 hex of the raw token
  scopes        String[]
  lastUsedAt    DateTime?
  issuedAt      DateTime  @default(now())
  expiresAt     DateTime?
  revokedAt     DateTime?
  revokedReason String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([revokedAt])
}

/// Short-lived pairing code the desktop exchanges for a DesktopToken.
/// Code is stored hashed too; the user sees the raw code once in the
/// web UI. TTL = 10 minutes.
model DesktopPairingCode {
  id              String    @id @default(cuid())
  userId          String
  codeHash        String    @unique
  expiresAt       DateTime
  consumedAt      DateTime?
  consumedTokenId String?
  createdAt       DateTime  @default(now())
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@index([consumedAt])
}

/// Rows written by the desktop app over the P5.4 token. Separate from
/// AutomationAuditLog (web-side reconciliation) so the observability
/// dashboards can filter cleanly. `payload` is sanitized by the desktop
/// writer before it leaves the machine - identity-read rows redact values.
model DesktopAuditLog {
  id              String   @id @default(cuid())
  userId          String
  tokenId         String?
  desktopSessionId String? // client-generated session UUID
  runtimeSessionId String? // ApplicationRuntimeSession id when applicable
  jobLeadId       String?
  toolName        String
  action          String   // e.g. "tool_call", "submit_attempt", "identity_read"
  outcome         String?  // "ok" | "error" | null when not applicable
  payload         Json
  redactedKeys    String[] @default([])
  errorMessage    String?
  durationMs      Int?
  createdAt       DateTime @default(now())
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([desktopSessionId, createdAt])
  @@index([toolName, createdAt])
  @@index([jobLeadId, createdAt])
  @@index([runtimeSessionId, createdAt])
}

