generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model ApplicationSubmission {
  confirmationState   ApplicationConfirmationState @default(PENDING)
  createdAt           DateTime                  @default(now())
  errorMessage        String?
  // Typed desktop-runtime failure reason (P17.1). One of the values in
  // DESKTOP_AGENT_SESSION_STATUSES — kept as String here rather than a
  // Prisma enum so the desktop runtime + the web ingest endpoint stay
  // the single source of truth and we don't need a migration on every
  // new typed reason. NULL when the run produced a non-failure status
  // (completed / paused_for_manual_review / blocked_by_submit_guard).
  failureReason       String?
  id                  String                    @id @default(cuid())
  jobLeadId           String
  metadata            Json?
  resumeId            String?
  status              ApplicationStatus         @default(PENDING)
  submissionUrl       String?
  submittedAt         DateTime?
  updatedAt           DateTime                  @updatedAt
  userId              String
  userAgent           String?
  verifiedAt          DateTime?
  wasAutomated        Boolean                   @default(false)
  daysSinceSubmission Int?
  daysToFinalOutcome  Int?
  daysToResponse      Int?
  finalOutcomeAt      DateTime?
  interviewCount      Int                       @default(0)
  lastStatusChangeAt  DateTime?
  responseReceivedAt  DateTime?
  outcomeEvents       ApplicationOutcomeEvent[]
  jobLead             JobLead                   @relation(fields: [jobLeadId], references: [id], onDelete: Cascade)
  resume              Resume?                   @relation(fields: [resumeId], references: [id], onDelete: SetNull)
  user                User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  guidedApplication   GuidedApplication?
  applicationEmails   ApplicationEmail[]
  followUpDraft       FollowUpDraft?
}

model PlanBoardTask {
  id               String          @id @default(cuid())
  taskId           String          @unique
  title            String          @default("")
  description      String?
  phaseId          String          @default("P?")
  phaseTitle       String          @default("Unassigned")
  acceptance       String?
  testsRequired    String?
  dependsOn        String[]        @default([])
  files            String[]        @default([])
  labels           String[]        @default([])
  sortOrder        Int             @default(0)
  status           PlanBoardStatus @default(TODO)
  agentHandle      String?
  claimedAt        DateTime?
  assignmentReason String?
  notes            String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  events           PlanBoardEvent[]

  @@index([status, updatedAt])
  @@index([status, claimedAt])
  @@index([phaseId, sortOrder])
}

model PlanBoardEvent {
  id                  String              @id @default(cuid())
  taskId              String
  eventType           PlanBoardEventType
  fromStatus          PlanBoardStatus?
  toStatus            PlanBoardStatus?
  agentHandle         String?
  previousAgentHandle String?
  nextAgentHandle     String?
  assignmentReason    String?
  message             String?
  createdAt           DateTime            @default(now())
  task                PlanBoardTask        @relation(fields: [taskId], references: [taskId], onDelete: Cascade)

  @@index([taskId, createdAt])
  @@index([eventType, createdAt])
}

model ApplicationOutcomeEvent {
  id                      String                @id @default(cuid())
  applicationSubmissionId String
  eventType               String
  previousStatus          ApplicationStatus?
  newStatus               ApplicationStatus
  metadata                Json?
  notes                   String?
  createdAt               DateTime              @default(now())
  createdBy               String?
  applicationSubmission   ApplicationSubmission @relation(fields: [applicationSubmissionId], references: [id], onDelete: Cascade)
}

model CoverLetter {
  createdAt           DateTime            @default(now())
  description         String?
  id                  String              @id @default(cuid())
  json                Json?
  leadId              String?
  markdown            String?
  name                String
  updatedAt           DateTime            @updatedAt
  userId              String
  lead                JobLead?            @relation(fields: [leadId], references: [id])
  user                User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  guidedApplications  GuidedApplication[]
  tailoredForLeads    JobLead[]           @relation("JobLeadTailoredCoverLetter")
}

model JobFitAnalysis {
  additionalMetrics        Json
  createdAt                DateTime             @default(now())
  educationRelevanceScore  Int
  experienceRelevanceScore Int
  summary                  String
  id                       String               @id @default(cuid())
  jobLeadId                String?              @unique
  jobListingId             String?
  keywordMatch             Json
  missingKeywords          String[]
  overallMatchScore        Int
  progress                 Int                  @default(0)
  recommendations          String[]
  resumeId                 String?
  resumeRevisionId         String?
  skillsAlignment          Json
  status                   JobFitAnalysisStatus @default(QUEUED)
  updatedAt                DateTime             @updatedAt
  userId                   String?
  jobLead                  JobLead?             @relation(fields: [jobLeadId], references: [id], onDelete: Cascade)
  jobListing               JobListing?          @relation(fields: [jobListingId], references: [id], onDelete: Cascade)
  resume                   Resume?              @relation(fields: [resumeId], references: [id], onDelete: Cascade)
  resumeRevision           ResumeRevision?      @relation(fields: [resumeRevisionId], references: [id])
  user                     User?                @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobLeadOptimization      JobLeadOptimization?
  resumeOptimization       ResumeOptimization?
}

model JobLead {
  createdAt                       DateTime                         @default(now())
  id                              String                           @id @default(cuid())
  jobListingId                    String                           @unique
  jobSearchId                     String?
  status                          JobLeadStatus                    @default(ADDED)
  submissionTier                  SubmissionTier                   @default(TARGETED)
  tailoredCoverLetterId           String?
  tailoredResumeRevisionId        String?
  title                           String
  updatedAt                       DateTime                         @updatedAt
  userId                          String
  applicationSubmissions          ApplicationSubmission[]
  automationScheduledApplications AutomationScheduledApplication[]
  coverLetters                    CoverLetter[]
  jobFitAnalysis                  JobFitAnalysis?
  jobListing                      JobListing                       @relation(fields: [jobListingId], references: [id], onDelete: Cascade)
  jobSearch                       JobSearch?                       @relation(fields: [jobSearchId], references: [id], onDelete: Cascade)
  tailoredCoverLetter             CoverLetter?                     @relation("JobLeadTailoredCoverLetter", fields: [tailoredCoverLetterId], references: [id])
  tailoredResumeRevision          ResumeRevision?                  @relation("JobLeadTailoredResume", fields: [tailoredResumeRevisionId], references: [id])
  user                            User                             @relation(fields: [userId], references: [id], onDelete: Cascade)
  optimization                    JobLeadOptimization?
  resumeOptimizations             ResumeOptimization[]
  resumeRevisions                 ResumeRevision?
  guidedApplications              GuidedApplication[]
  applicationEmails               ApplicationEmail[]
  interviewQuestions              InterviewQuestion[]
  interviewSessions               InterviewSession[]

  @@index([userId, status])
  @@index([userId, createdAt])
}

model JobLeadOptimization {
  createdAt        DateTime                  @default(now())
  id               String                    @id @default(cuid())
  jobFitAnalysisId String?                   @unique
  jobLeadId        String                    @unique
  progress         Int                       @default(0)
  resumeRevisionId String?                   @unique
  status           JobLeadOptimizationStatus @default(QUEUED)
  updatedAt        DateTime                  @updatedAt
  userId           String?
  metadata         Json?                     // Pipeline context for durable state machine
  jobFitAnalysis   JobFitAnalysis?           @relation(fields: [jobFitAnalysisId], references: [id])
  jobLead          JobLead                   @relation(fields: [jobLeadId], references: [id], onDelete: Cascade)
  resumeRevision   ResumeRevision?           @relation(fields: [resumeRevisionId], references: [id])
  user             User?                     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model JobListing {
  applyOptions             Json?
  benefits                 String[]
  company                  String?
  companyLogoUrl           String?
  createdAt                DateTime         @default(now())
  dentalCoverage           Boolean?
  description              String?
  detectedExtensions       Json?
  extendedDetailsCollected Boolean?         @default(false)
  extensions               String[]
  healthInsurance          Boolean?
  id                       String           @id @default(cuid())
  jobProvider              JobProvider?     @map("jobBoard")
  jobProviderUrl           String?          @map("jobBoardUrl")
  jobId                    String           @unique
  jobType                  JobType?
  location                 String?
  paidTimeOff              Boolean?
  postedAt                 DateTime?
  qualifications           String[]         @default([])
  remote                   Boolean?
  requirements             String[]         @default([])
  responsibilities         String[]         @default([])
  salary                   String?
  saved                    Boolean          @default(false)
  scheduleType             String?
  source                   String?
  status                   JobListingStatus @default(UNREVIEWED)
  title                    String
  updatedAt                DateTime         @updatedAt
  userId                   String
  workFromHome             Boolean?
  jobFitAnalyses           JobFitAnalysis[]
  lead                     JobLead?
  jobSearchListings        JobSearchListing[]
  user                     User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([userId, postedAt])
  @@index([userId, createdAt])
  @@index([userId, saved])
  @@index([userId, status, postedAt])
  @@index([source])
}

model JobSearch {
  completedAt  DateTime?
  createdAt    DateTime        @default(now())
  endedAt      DateTime?
  errorMessage String?
  id           String          @id @default(cuid())
  jobProvider     JobProvider?     @map("jobBoard")
  jobProviderUrl  String?          @map("jobBoardUrl")
  location     String?
  nextToken    String?
  pageDelay    Int?
  progress     Int             @default(0)
  remote       Boolean?
  saved        Boolean         @default(false)
  searchTerm   String
  status       JobSearchStatus @default(QUEUED)
  totalJobs    Int?
  updatedAt    DateTime        @updatedAt
  userId       String
  metadata     Json?
  jobLeads     JobLead[]
  jobSearchListings JobSearchListing[]
  user         User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, saved])
  @@index([userId, createdAt])
  @@index([userId, status])
}

model JobSearchListing {
  createdAt     DateTime   @default(now())
  jobSearchId   String
  jobListingId  String
  jobSearch     JobSearch  @relation(fields: [jobSearchId], references: [id], onDelete: Cascade)
  jobListing    JobListing @relation(fields: [jobListingId], references: [id], onDelete: Cascade)

  @@id([jobSearchId, jobListingId])
  @@index([jobListingId])
}

model LinkedInProfile {
  createdAt         DateTime @default(now())
  email             String?
  firstName         String
  headline          String?
  id                String   @id @default(cuid())
  importedAt        DateTime
  lastName          String
  linkedInId        String
  locationCity      String?
  locationCountry   String?
  profileData       Json?
  profilePictureUrl String?
  publicProfileUrl  String?
  updatedAt         DateTime @updatedAt
  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, linkedInId])
}

model ResumeAnalysis {
  achievements     Json?
  createdAt        DateTime             @default(now())
  formatting       Json?
  grammar          Json?
  id               String               @id @default(cuid())
  keywords         Json?
  likeability      Json?
  progress         Int                  @default(0)
  readability      Json?
  recommendations  Json?
  score            Int?
  sections         Json?
  resumeId         String?              @unique
  resumeRevisionId String?              @unique
  spelling         Json?
  status           ResumeAnalysisStatus @default(QUEUED)
  strengths        String[]
  summary          String?
  updatedAt        DateTime             @updatedAt
  userId           String
  weaknesses       String[]
  resume           Resume?              @relation(fields: [resumeId], references: [id], onDelete: Cascade)
  resumeRevision   ResumeRevision?      @relation(fields: [resumeRevisionId], references: [id])
  user             User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  optimization     ResumeOptimization?
}

model ResumeOptimization {
  analysisId                    String?                  @unique
  changelog                     Json?
  estimatedVisibilityBoost      String?
  projectedShortlistProbability Float?
  createdAt                     DateTime                 @default(now())
  id                            String                   @id @default(cuid())
  jobFitAnalysisId              String?                  @unique
  jobLeadId                     String?
  optimizationStrategy          String?
  scoreImprovement              Float?
  score                         Float?
  status                        ResumeOptimizationStatus @default(QUEUED)
  previousScore                 Int?
  progress                      Int                      @default(0)
  resumeId                      String?                  @unique
  resumeRevisionId              String?                  @unique
  scoreDelta                    Float?
  scorePercentChange            Float?
  significantImprovements       String[]
  summary                       String?
  updatedAt                     DateTime                 @updatedAt
  userId                        String?
  analysis                      ResumeAnalysis?          @relation(fields: [analysisId], references: [id])
  jobFitAnalysis                JobFitAnalysis?          @relation(fields: [jobFitAnalysisId], references: [id])
  jobLead                       JobLead?                 @relation(fields: [jobLeadId], references: [id], onDelete: Cascade)
  resume                        Resume?                  @relation(fields: [resumeId], references: [id], onDelete: Cascade)
  resumeRevision                ResumeRevision?          @relation(fields: [resumeRevisionId], references: [id])
  user                          User?                    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Resume {
  analysisId             String?                   @unique
  id                     String                    @id @default(cuid())
  createdAt              DateTime                  @default(now())
  defaultRevisionId      String?                   @unique
  description            String?
  filename               String?
  format                 ResumeFormat?
  json                   Json?
  markdown               String?
  name                   String
  updatedAt              DateTime                  @updatedAt
  url                    String?
  userId                 String
  kind                   ResumeKind                @default(UPLOADED)
  structuredData         Json?
  applicationSubmissions ApplicationSubmission[]
  jobFitAnalyses         JobFitAnalysis[]
  user                   User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  analysis               ResumeAnalysis?
  optimization           ResumeOptimization?
  performanceMetrics     ResumePerformanceMetric[]
  revisions              ResumeRevision[]
  guidedApplications     GuidedApplication[]
}

model Session {
  createdAt DateTime @default(now())
  expiresAt DateTime
  id        String   @id @default(cuid())
  ipAddress String?
  token     String   @unique
  updatedAt DateTime @updatedAt
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("session")
}

model ResumeRevision {
  id                  String                    @id @default(cuid())
  createdAt           DateTime                  @default(now())
  description         String?
  format              ResumeFormat?
  formats             Json?
  jobLeadId           String?                   @unique
  json                Json?
  markdown            String?
  name                String
  pdfDocumentUrl      String?
  resumeAnalysisId    String?                   @unique
  resumeId            String
  updatedAt           DateTime                  @updatedAt
  wordDocumentUrl     String?
  userId              String
  jobFitAnalyses      JobFitAnalysis[]
  jobLeadOptimization JobLeadOptimization?
  resumeAnalysis      ResumeAnalysis?
  optimization        ResumeOptimization?
  performanceMetrics  ResumePerformanceMetric[]
  jobLead             JobLead?                  @relation(fields: [jobLeadId], references: [id], onDelete: Cascade)
  resume              Resume                    @relation(fields: [resumeId], references: [id], onDelete: Cascade)
  user                User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tailoredForLeads    JobLead[]                 @relation("JobLeadTailoredResume")
}

model InterviewQuestion {
  id                String             @id @default(cuid())
  type              String
  question          String
  description       String?
  difficulty        String
  jobLeadId         String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  userId            String
  jobLead           JobLead?           @relation(fields: [jobLeadId], references: [id], onDelete: SetNull)
  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  interviewSessions InterviewSession[] @relation("InterviewSessionQuestions")
  responses         InterviewResponse[]

  @@index([userId, createdAt])
  @@index([jobLeadId])
}

model InterviewResponse {
  id                String             @id @default(cuid())
  questionId        String
  answer            String
  feedback          String?
  score             Float?
  quality           String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  userId            String
  question          InterviewQuestion  @relation(fields: [questionId], references: [id], onDelete: Cascade)
  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  interviewSessions InterviewSession[] @relation("InterviewSessionResponses")

  @@index([userId, createdAt])
  @@index([questionId])
}

model InterviewSession {
  id            String              @id @default(cuid())
  name          String?
  description   String?
  status        String              @default("IN_PROGRESS")
  totalScore    Float?
  averageScore  Float?
  source        String?
  sourceEmailId String?             @unique
  metadata      Json?
  jobLeadId     String?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  userId        String
  jobLead       JobLead?            @relation(fields: [jobLeadId], references: [id], onDelete: SetNull)
  user          User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  questions     InterviewQuestion[] @relation("InterviewSessionQuestions")
  responses     InterviewResponse[] @relation("InterviewSessionResponses")

  @@index([userId, createdAt])
  @@index([jobLeadId])
}

model Subscription {
  cancelAtPeriodEnd    Boolean  @default(false)
  createdAt            DateTime @default(now())
  currentPeriodEnd     DateTime
  currentPeriodStart   DateTime @default(now())
  id                   String   @id @default(cuid())
  plan                 String
  priceId              String?
  status               String
  stripeCustomerId     String   @unique
  stripeSubscriptionId String   @unique
  updatedAt            DateTime @updatedAt
  userId               String   @unique
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([stripeCustomerId])
}

model User {
  createdAt                       DateTime                         @default(now())
  defaultResumeId                 String?                          @unique
  defaultRevisionId               String?                          @unique
  email                           String                           @unique
  emailVerified                   Boolean                          @default(false)
  firstName                       String
  id                              String                           @id @default(cuid())
  image                           String?                          @default("/user.png")
  lastName                        String
  name                            String?
  phone                           String?                          @unique
  phoneVerified                   DateTime?
  updatedAt                       DateTime                         @updatedAt
  applicationSubmissions          ApplicationSubmission[]
  automationAuditLogs             AutomationAuditLog[]
  automationScheduledApplications AutomationScheduledApplication[]
  automationSettings              AutomationSettings?
  CodeMetric                      CodeMetric[]
  coverLetters                    CoverLetter[]
  DeploymentMetric                DeploymentMetric[]
  DeveloperMetric                 DeveloperMetric[]
  IncidentMetric                  IncidentMetric[]
  jobFitAnalyses                  JobFitAnalysis[]
  leads                           JobLead[]
  jobLeadOptimizations            JobLeadOptimization[]
  jobListings                     JobListing[]
  jobSearches                     JobSearch[]
  linkedInProfiles                LinkedInProfile[]
  mobileAudits                    MobileResponsivenessAudit[]
  notifications                   Notification[]
  peopleProfiles                  PeopleProfile[]
  assistTrainingSessions          AssistTrainingSession[]
  applicationRuntimeSessions      ApplicationRuntimeSession[]
  applicationRuntimeEvents        ApplicationRuntimeEvent[]
  runtimeTrainingReviews          RuntimeTrainingReview[]
  atsAnalysisJobs                 ATSAnalysisJob[]
  rulePromotionCandidates         RulePromotionCandidate[]
  ProductivityMetric              ProductivityMetric[]
  resumes                         Resume[]
  resumeAnalyses                  ResumeAnalysis[]
  resumeOptimizations             ResumeOptimization[]
  resumePerformanceMetrics        ResumePerformanceMetric[]
  resumeRevisions                 ResumeRevision[]
  subscription                    Subscription?
  jobPreferences                  UserJobPreferences?
  profile                         UserProfile?
  verificationTokens              VerificationToken[]
  accounts                        Account[]
  sessions                        Session[]
  guidedApplications              GuidedApplication[]
  trackingEmailAlias              String?                          @unique
  trackingEmailForwardingEnabled  Boolean                          @default(false)
  trackingEmailSetupAt            DateTime?
  // When true, desktop submissions upload the per-lead tailored resume.
  // Default false — submissions use the user's stored default resume.
  // Tailored revisions are still saved on the JobLead for history.
  useOptimizedResumeOnSubmit      Boolean                          @default(false)
  applicationEmails               ApplicationEmail[]
  atsFieldObservations            ATSFieldObservation[]
  knowledge                       UserKnowledge[]
  confirmationInboxes             ConfirmationInbox[]
  followUpDrafts                  FollowUpDraft[]
  desktopTokens                   DesktopToken[]
  desktopPairingCodes             DesktopPairingCode[]
  desktopAuditLogs                DesktopAuditLog[]
  localFormSnapshots              LocalFormSnapshot[]
  formFieldFeedbacks              FormFieldFeedback[]
  userFieldRules                  UserFieldRule[]
  userCredentials                 UserCredential[]
  interviewQuestions              InterviewQuestion[]
  interviewResponses              InterviewResponse[]
  interviewSessions               InterviewSession[]
  runtimeTrustOverrides           RuntimeTrustOverride[]
  scrapeSessions                  ScrapeSession[]

  @@map("user")
}

model UserJobPreferences {
  city            String?
  companySize     CompanySize?
  companyType     String?
  createdAt       DateTime         @default(now())
  experienceLevel ExperienceLevel?
  id              String           @id @default(cuid())
  jobTitles       String[]
  preferRemote    Boolean?
  remoteOnly      Boolean?
  state           String?
  updatedAt       DateTime         @updatedAt
  userId          String           @unique
  zipCode         String?
  timezone        String?          @default("America/New_York")
  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UserProfile {
  city                         String?
  createdAt                    DateTime @default(now())
  disabilityStatus             String?
  earliestStartDate            String?
  educationDegree              String?
  educationEndMonth            Int?
  educationEndYear             Int?
  educationInstitution         String?
  educationInstitutionLocation String?
  educationStartMonth          Int?
  educationStartYear           Int?
  emailAddress                 String?
  firstName                    String?
  gender                       String?
  githubUrl                    String?
  id                           String   @id @default(cuid())
  lastName                     String?
  linkedinUrl                  String?
  personalWebsiteUrl           String?
  phoneNumber                  String?
  preferredName                String?
  pronouns                     String?
  race                         String?
  requiresSponsorship          Boolean?
  salaryExpectation            String?
  state                        String?
  streetAddress                String?
  transgenderIdentity          String?
  updatedAt                    DateTime @updatedAt
  userId                       String?  @unique
  veteranStatus                String?
  websiteUrl                   String?
  workAuthorization            String?
  yearsOfExperience            String?
  zipCode                      String?
  user                         User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  expires    DateTime?
  identifier String
  token      String    @unique
  userId     String
  user       User      @relation(fields: [userId], references: [id])

  @@unique([identifier, token])
}

model Account {
  accessToken           String?
  accessTokenExpiresAt  DateTime?
  accountId             String
  createdAt             DateTime  @default(now())
  id                    String    @id
  idToken               String?
  password              String?
  providerId            String
  refreshToken          String?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  updatedAt             DateTime  @updatedAt
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("account")
}

model Verification {
  id         String    @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime?
  updatedAt  DateTime?

  @@map("verification")
}

model MobileResponsivenessAudit {
  id                   String   @id @default(cuid())
  userId               String
  createdAt            DateTime @default(now())
  score                Int
  highSeverityIssues   Int
  mediumSeverityIssues Int
  lowSeverityIssues    Int
  totalIssues          Int
  auditData            Json?
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Notification {
  id           String               @id @default(cuid())
  userId       String
  title        String
  message      String
  type         NotificationCategory     @default(SYSTEM)
  eventType    String?
  status       NotificationStatus       @default(PENDING)
  channels     NotificationChannel[]
  actionUrl    String?
  actionLabel  String?
  isRead       Boolean              @default(false)
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  expiresAt    DateTime?
  metadata     Json?
  priority     NotificationPriority @default(MEDIUM)
  user         User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  deliveries   NotificationDelivery[]

  @@index([userId])
}

model NotificationDelivery {
  id             String             @id @default(cuid())
  notificationId String
  channel        NotificationChannel
  provider       String
  status         NotificationStatus @default(UNREAD)
  payload        Json?
  sentAt         DateTime?
  deliveredAt    DateTime?
  failedAt       DateTime?
  errorMessage   String?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  notification   Notification       @relation(fields: [notificationId], references: [id], onDelete: Cascade)

  @@index([notificationId])
}

model NotificationPreference {
  id        String              @id @default(cuid())
  userId    String
  eventType String
  channel   NotificationChannel
  enabled   Boolean             @default(true)
  digest    NotificationDigest  @default(NONE)
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt

  @@unique([userId, eventType, channel])
  @@index([userId])
}

model PeopleProfile {
  id                  String   @id @default(cuid())
  userId              String
  name                String
  company             String
  title               String?
  linkedinUrl         String?
  summary             String?
  experience          String[]
  education           String[]
  skills              String[]
  articles            String[]
  socialProfiles      Json?
  personalityData     Json?
  interviewStrategy   Json?
  researchSources     String[]
  notes               String?
  tags                String[]
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
