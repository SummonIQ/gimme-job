model FormFieldFeedback {
  applicationUrl String?
  createdAt      DateTime                       @default(now())
  feedback       String
  fieldLabel     String
  fieldSelector  String?
  fieldType      String?
  filledValue    String?
  hostname       String
  id             String                         @id @default(cuid())
  rejectReason   String?
  snapshotId     String?
  status         String?
  updatedAt      DateTime                       @updatedAt
  userId         String
  // Semantic embedding of fieldLabel for similarity search against new
  // questions. Populated lazily by the resolver when missing. See
  // lib/field-answer/embeddings.ts.
  embedding      Unsupported("vector(768)")?
  user           User                           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, hostname])
  @@index([userId, fieldLabel])
}

// User-taught rules for filling form fields. Persists across desktop
// installs and is consumable by the web's AI-assist flow so a rule
// taught on one device applies everywhere.
//
//   hostname:   null = global rule (matches any site)
//               "<domain>" = scoped to that ATS host
//   question:   substring matched against the field's label, case-insensitive
//   answer:     literal value typed/selected for matching fields
//   source:     where the rule was taught — "manual" / "state-tab" / "chat"
// Per-user login credentials for ATS / job-board sites. Used by the
// resolver to autofill username/password fields and (eventually) to
// auto-log-in when an application page sits behind a sign-in wall.
//
// Storage model: username is plaintext (needed to disambiguate when a
// user has multiple accounts on the same hostname, and to feed the
// resolver's "match by username" path). Password is encrypted at the
// app layer with AES-256-GCM via lib/credentials/cipher.ts; the
// `password` blob format is `iv (12B) || authTag (16B) || ciphertext`.
// The encryption key lives in env (`CREDENTIAL_ENCRYPTION_KEY`), so a
// DB dump alone does not yield plaintext.
model UserCredential {
  id        String   @id @default(cuid())
  userId    String
  hostname  String
  label     String?
  username  String
  password  Bytes
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, hostname, username])
  @@index([userId, hostname])
}

model UserFieldRule {
  id        String                         @id @default(cuid())
  userId    String
  hostname  String?
  question  String
  answer    String
  source    String                         @default("manual")
  createdAt DateTime                       @default(now())
  updatedAt DateTime                       @updatedAt
  // Semantic embedding of `question` for similarity search.
  embedding Unsupported("vector(768)")?
  user      User                           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, hostname])
  @@index([userId, question])
}
