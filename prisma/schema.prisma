/// Manual trust overrides keyed to a runtime-trust scope tuple. Only
/// demotions are stored here — promotions must flow through the P8.1
/// ladder's signal evidence. Active rows cap the scope's level at
/// `demotedTo`; an expiredAt past `now` is ignored.
model RuntimeTrustOverride {
  id                    String    @id @default(cuid())
  userId                String
  atsFamily             String
  hostname              String
  node                  String?
  transition            String?
  actionType            String
  demotedTo             String    // TrustLevel value
  reason                String
  createdAt             DateTime  @default(now())
  expiresAt             DateTime?
  clearedAt             DateTime?
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, atsFamily, hostname])
  @@index([clearedAt, expiresAt])
}

model ATSSystem {
  id                    String   @id @default(cuid())
  name                  String   // e.g., "Greenhouse", "Lever", "Workday"
  vendor                String?  // Vendor name if different from product name
  detectedDomain        String?  // Domain pattern like "greenhouse.io"
  domainPatterns        String[] // Multiple domain patterns
  
  // Network analysis
  apiEndpoints          Json?    // Detected API endpoints used by the ATS
  networkPatterns       Json?    // Network request patterns (headers, params, etc.)
  xhrCalls              Json?    // XHR/Fetch calls made during application
  cookieRequirements    Json?    // Required cookies and sessions
  csrfTokenPatterns     Json?    // CSRF token locations and patterns
  
  // Form and field analysis
  commonStructures      Json     // Common HTML structures, input IDs, class names
  formPatterns          Json     // Form submission patterns
  fieldMappings         Json     // Field name -> HTML selector mappings
  requiredFields        String[] // Fields that are always required
  optionalFields        String[] // Fields that are sometimes present
  hiddenFields          Json?    // Hidden fields and their typical values
  
  // File upload handling
  resumeUploadMethod    String?  // How resume uploads work
  resumeFieldSelectors  String[] // Selectors for resume upload fields
  supportedFileTypes    String[] // Accepted file types
  maxFileSize           Int?     // Max file size in bytes

  // Resume autofill behavior
  resumeUploadGatesAutofill       Boolean  @default(false) // Resume must be uploaded before batch autofill works
  resumeAutofillContainerSelector String?  // CSS selector for the resume autofill UI container
  resumeUploadApiPath             String?  // API path to wait for upload completion confirmation
  
  // Multi-step detection
  isMultiStep           Boolean  @default(false)
  stepCount             Int?     // Number of steps if multi-step
  stepPatterns          Json?    // How to detect/navigate steps
  
  // Identification
  uniqueIdentifiers     Json     // Unique ways to identify this ATS
  metaTags              Json?    // Meta tags that identify this ATS
  scriptUrls            String[] // JavaScript URLs that indicate this ATS
  styleUrls             String[] // CSS URLs that indicate this ATS
  
  // Behavior and quirks
  nuances               String[] // Special behaviors, quirks, notes
  javascriptDependency  String?  // JS requirements (React, Angular, etc.)
  waitTimeNeeded        Int?     // Milliseconds to wait for page load
  requiresInteraction   Boolean  @default(false) // Needs clicks before form appears
  
  // AI-generated insights
  aiVisualAnalysis      String?  // GPT-4 Vision analysis of screenshots
  aiUxPatterns          String[] // UX patterns identified by AI
  aiKeyObservations     String[] // Key observations from AI
  aiRecommendedApproach String?  // AI's recommended automation approach
  
  // Success metrics
  difficulty            String?  // "Easy", "Medium", "Hard"
  successRate           Float?   // Success rate of automated submissions
  avgCompletionTime     Int?     // Average time to complete application (seconds)
  
  // Examples and samples
  sampleUrls            String[] // Sample job URLs using this ATS
  screenshotUrls        String[] // Screenshots of the application flow
  
  // Analysis metadata
  lastAnalyzed          DateTime @default(now())
  totalAnalyzed         Int      @default(0)
  lastSuccessfulSubmit  DateTime?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  fieldObservations     ATSFieldObservation[]
  runtimeSessions       ApplicationRuntimeSession[]
  rules                 ATSRule[]
  rulePromotionCandidates RulePromotionCandidate[]
  flowDefinitions       ApplicationFlowDefinition[]
  flowNodes             ApplicationFlowNode[]
  submissionConfirmationPhrases SubmissionConfirmationPhrase[]
  networkRecipes        NetworkSubmissionRecipe[]

  @@index([name])
  @@index([detectedDomain])
  @@index([vendor])
}

