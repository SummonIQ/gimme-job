/// A single page/state in a multi-step application flow. Unlike
/// `ApplicationFlowStepDefinition` (which is a compiled step inside a
/// named flow), a `ApplicationFlowNode` represents an OBSERVED distinct
/// page reached during training or real runs. Nodes are identified by a
/// structural fingerprint (tag/class/aria signature of the visible
/// fields + action surfaces) so the same conceptual page matches across
/// job IDs, user sessions, and minor markup variations.
///
/// This model is the foundation for the fully-automated submission
/// state machine: the runtime can then answer "where am I in this ATS
/// flow?" by fingerprinting the current page and looking up the node.
model ApplicationFlowNode {
  id                  String   @id @default(cuid())
  atsSystemId         String?
  hostname            String
  /// SHA-256 of the sorted, normalized list of visible field signatures.
  /// Two visits to the same conceptual page produce the same fingerprint.
  pageFingerprint     String
  /// Human-facing label we show in the UI (e.g. "Personal Info",
  /// "Resume Upload", "EEO Questions", "Review & Submit"). Derived from
  /// heading text / section titles / vision classification.
  nodeLabel           String?
  /// Canonical list of required field signatures on this page. Auto-submit
  /// asserts each one is filled before firing the transition.
  requiredFields      Json     @default("[]")
  /// Optional fields observed on the page (for context, not gating).
  optionalFields      Json     @default("[]")
  /// Post-condition checks that confirm we've advanced OFF this page.
  /// Structured as a list of { kind: 'url-contains' | 'text-absent' | 'element-absent' | 'url-changed', value: string }.
  exitConditions      Json     @default("[]")
  /// How many distinct successful runs have observed this exact node.
  observationCount    Int      @default(1)
  /// How many times auto-submit has landed here in a run (completed + failed).
  visitCount          Int      @default(0)
  /// How many times we've successfully transitioned off this node.
  successfulExitCount Int      @default(0)
  /// Rolling confidence 0-1 derived from observation/exit counts.
  confidence          Float    @default(0.2)
  /// Free-form notes captured from vision or the training annotator.
  notes               String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  atsSystem           ATSSystem? @relation(fields: [atsSystemId], references: [id], onDelete: SetNull)
  outgoingTransitions ApplicationFlowTransition[] @relation("FlowNodeOutgoing")
  incomingTransitions ApplicationFlowTransition[] @relation("FlowNodeIncoming")

  @@unique([hostname, pageFingerprint])
  @@index([hostname])
  @@index([atsSystemId])
  @@index([pageFingerprint])
}

/// A directed edge between two `ApplicationFlowNode`s. Represents "click
/// this selector on node A and you'll land on node B." Multiple training
/// observations of the same transition increment `observationCount`;
/// confidence grows with repeated successful traversals.
model ApplicationFlowTransition {
  id               String   @id @default(cuid())
  fromNodeId       String
  toNodeId         String
  /// The selector (usually a button) that triggers the transition.
  triggerSelector  String
  /// Human label for the trigger (e.g. "Continue", "Next", "Submit Application").
  triggerLabel     String?
  /// The action type on the trigger — "click", "submit", "keypress", etc.
  actionType       String   @default("click")
  observationCount Int      @default(1)
  successCount     Int      @default(0)
  failureCount     Int      @default(0)
  confidence       Float    @default(0.2)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  fromNode         ApplicationFlowNode @relation("FlowNodeOutgoing", fields: [fromNodeId], references: [id], onDelete: Cascade)
  toNode           ApplicationFlowNode @relation("FlowNodeIncoming", fields: [toNodeId], references: [id], onDelete: Cascade)

  @@unique([fromNodeId, triggerSelector, toNodeId])
  @@index([fromNodeId])
  @@index([toNodeId])
}

model ATSFieldObservation {
  id           String     @id @default(cuid())
  userId       String
  hostname     String
  pathname     String?
  atsSystemId  String?
  source       ApplicationRuntimeSource @default(LEGACY)

  // Element metadata
  selector        String   // Best reproducible CSS selector for the element
  stableSelector  String?  // Preferred selector using label/aria/role (no random IDs)
  tagName         String
  inputType       String?
  fieldName       String?
  fieldId         String?
  fieldLabel      String?
  ariaLabel       String?
  placeholder     String?
  autocomplete    String?
  role            String?  // ARIA role attribute

  // Step sequence tracking
  stepIndex    Int      @default(0) // Order within a single application session
  sessionId    String?  // Groups observations from one application session

  // Field constraints & metadata (for future AI context)
  fieldDisplayName String?  // Human-friendly name (e.g., "Phone Number", "ZIP Code")
  maxLength        Int?     // maxlength attribute
  minLength        Int?     // minlength attribute
  pattern          String?  // pattern attribute (regex)
  inputMode        String?  // inputmode attribute (numeric, tel, email, etc.)
  fieldConstraints Json?    // Additional constraints: { autoFormat, numbersOnly, allowedChars, etc. }

  // Action context
  action       String   // "continue" or "skip"
  actionType   String   // "fill", "click", "upload", "activate"
  aiReason     String?
  valueFilled  String?  // PII-redacted
  success      Boolean  @default(true)
  // Did the DOM/URL actually change in the expected way after this action?
  // Separates "click landed" from "click accomplished what it was supposed to".
  postConditionMet Boolean?
  // True when this field looks like a honeypot (hidden/off-screen/tabindex=-1)
  // and was deliberately skipped during training.
  isHoneypot   Boolean @default(false)

  // Dedup tracking
  observationCount Int  @default(1) // Incremented on duplicates instead of creating new rows

  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @default(now()) @updatedAt
  // Semantic embedding of fieldLabel for cross-hostname rule matching.
  embedding    Unsupported("vector(768)")?
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  atsSystem    ATSSystem? @relation(fields: [atsSystemId], references: [id], onDelete: SetNull)

  @@unique([hostname, stableSelector, action, actionType], name: "unique_observation")
  @@index([hostname])
  @@index([hostname, tagName])
  @@index([hostname, stepIndex])
  @@index([userId])
  @@index([atsSystemId])
  @@index([sessionId])
}

model ATSRule {
  id             String     @id @default(cuid())
  hostname       String
  atsSystemId    String?

  // What to do
  action         String     // "continue" or "skip"
  actionType     String     // "fill", "click", "upload", "activate"

  // Element targeting
  stableSelector String     // Reproducible CSS selector
  tagName        String
  fieldName      String?
  fieldLabel     String?
  ariaLabel      String?
  role           String?

  // Step sequence
  stepIndex      Int        @default(0) // Position in the application flow
  reason         String?    // Why this rule exists

  // Promotion tracking
  observationCount     Int      @default(0) // How many observations led to this rule
  confidence           Float    @default(1.0) // 0-1 confidence score
  enabled              Boolean  @default(true)
  consecutiveFailures  Int      @default(0) // Auto-disable after threshold
  source               ApplicationRuntimeSource @default(LEGACY)

  // Provenance — which training sessions contributed observations that
  // promoted this rule. Lets us surgically roll back rules from a bad
  // training run without touching unrelated rules.
  sourceTrainingSessionIds String[] @default([])

  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  // Semantic embedding of fieldLabel for cross-hostname rule lookup.
  embedding      Unsupported("vector(768)")?
  atsSystem      ATSSystem? @relation(fields: [atsSystemId], references: [id], onDelete: SetNull)
  trainingReviews RuntimeTrainingReview[]

  @@unique([hostname, stableSelector, action], name: "unique_rule")
  @@index([hostname])
  @@index([hostname, stepIndex])
  @@index([atsSystemId])
  @@index([source])
}

