{
  "name": "gimme-job",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev && prisma generate",
    "db:push": "prisma db push && prisma generate",
    "db:reset": "prisma migrate reset",
    "db:studio": "prisma studio --port 10101 --browser none",
    "deps:check": "ncu -i --format group -p bun",
    "dev": "bun scripts/dev.ts",
    "dev:web": "bun next dev --webpack --port 10100",
    "desktop:dev": "cd desktop && bun run dev",
    "dev:e2e": "NEXT_DIST_DIR=.next-e2e bun next dev --turbopack --port 10110",
    "build": "bun db:generate && next build",
    "yolo": "git add . && git commit -m 'yolo' && git push",
    "start": "next start --port 10100",
    "start:e2e": "next start --port 10110",
    "lint": "next lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:unit": "vitest run lib/**/__tests__",
    "test:a11y": "vitest run __tests__/a11y",
    "test:contrast": "vitest run __tests__/a11y/contrast-audit.test.ts",
    "test:e2e": "playwright test --project=chromium",
    "test:e2e:ui": "playwright test --project=chromium --ui",
    "test:e2e:debug": "playwright test --project=chromium --debug",
    "test:e2e:codegen": "playwright codegen http://localhost:10110",
    "playwright:install": "playwright install",
    "record:demo": "bun scripts/record-demo.ts",
    "jobs:ingest": "bun scripts/ingest-job-dataset.ts",
    "jobs:ingest:backfill": "bun scripts/ingest-job-dataset.ts --mode=backfill",
    "jobs:ingest:sync": "bun scripts/ingest-job-dataset.ts --mode=sync",
    "dev:ios": "cd mobile && bun start --ios",
    "dev:android": "cd mobile && bun start --android"
  },
