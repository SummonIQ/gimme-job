# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/.next-e2e/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# prisma
/generated/

# Sentry Config File
.env.sentry-build-plugin
.playwright/

# Agent file-lock coordination — locks are filesystem-only, not history.
.agent-locks/**/*.lock

# Desktop installer build output
desktop/release/
public/downloads/

# Local MCP server config (may contain API keys)
.mcp.json

# Claude Code agent worktrees (large, ephemeral)
.claude/worktrees/

# Local secrets and machine-specific credentials
.env
.env.*
!.env.example
!.env.*.example
.npmrc
!.npmrc.example
.pypirc
.netrc
credentials
credentials.json
service-account.json
*.pem
*.key
*.p12
*.mobileprovision
